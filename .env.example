# Bot Telegram
BOT_TOKEN=

# Postgres (DB Supabase su VPS, raggiunto via docker network)
DATABASE_URL=postgres://postgres:PASSWORD@supabase_db_maestro-test:5432/postgres

# Whitelist chat ID — separati da virgola
AUTHORIZED_CHAT_IDS=

# Mappa chat_id → socio (un chat ID per socio)
DAVIDE_CHAT_ID=
ASCANIO_CHAT_ID=

# Chat ID del gruppo Telegram "Ecologicaleaving" (negativo, es. -1001234567890).
# Ricavabile da /start nel gruppo o dai log del bot.
# Necessario per F1 (cattura inbound) — se assente, on_group_message funziona ugualmente
# ma il campo group_chat_id in Config sarà None.
GROUP_CHAT_ID=

# Briefing mattutino
BRIEFING_HOUR=7
BRIEFING_TIMEZONE=Europe/Rome

# Logging
LOG_LEVEL=INFO
